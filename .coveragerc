[run]
source = src
branch = true
omit =
    */tests/*
    */__pycache__/*
    */migrations/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
show_missing = true
fail_under = 80

[html]
directory = htmlcov

[xml]
output = coverage.xml
